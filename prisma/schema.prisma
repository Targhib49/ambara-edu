generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TUTOR
  STUDENT
}

enum StudentGroup {
  JUNIOR_HIGH
  UNDERGRAD
  GRAD
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum BlockType {
  MARKDOWN
  EQUATION
  CODE_SNIPPET
  FILE_ATTACHMENT
  CODE_EDITOR
  VISUALIZATION
  // later phases append: VIDEO_EMBED, QUIZ_REF
}

enum SessionStatus {
  PROPOSED
  CONFIRMED
  RESCHEDULE_REQUESTED_BY_STUDENT
  RESCHEDULE_REQUESTED_BY_TUTOR
  CANCELLED
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTI_SELECT
  NUMERIC
  SHORT_TEXT
  CODE
}

enum SubmissionStatus {
  AUTO_GRADED
  PENDING_REVIEW
  REVIEWED
}

model User {
  id                String        @id @db.Uuid // = Supabase auth.users.id
  email             String        @unique
  name              String
  role              Role          @default(STUDENT)
  studentGroup      StudentGroup? // display/defaults only, not an access constraint
  enrollments       Enrollment[]
  ownedTracks       Track[]       @relation("TrackOwner")
  sessionsAsStudent Session[]     @relation("SessionStudent")
  sessionsAsTutor   Session[]     @relation("SessionTutor")
  submissions       Submission[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Track {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String       @default("")
  ownerId     String       @db.Uuid
  owner       User         @relation("TrackOwner", fields: [ownerId], references: [id])
  modules     Module[]
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Enrollment {
  studentId String   @db.Uuid
  trackId   String   @db.Uuid
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([studentId, trackId])
  @@index([trackId])
}

model Module {
  id        String   @id @default(uuid()) @db.Uuid
  trackId   String   @db.Uuid
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackId, order])
}

model Lesson {
  id        String         @id @default(uuid()) @db.Uuid
  moduleId  String         @db.Uuid
  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  status    LessonStatus   @default(DRAFT)
  blocks    ContentBlock[]
  quizzes   Quiz[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([moduleId, order])
}

model ContentBlock {
  id        String    @id @default(uuid()) @db.Uuid
  lessonId  String    @db.Uuid
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order     Int
  type      BlockType
  data      Json // shape validated per-type by Zod at the app boundary
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([lessonId, order])
}

model Session {
  id              String        @id @default(uuid()) @db.Uuid
  studentId       String        @db.Uuid
  tutorId         String        @db.Uuid
  student         User          @relation("SessionStudent", fields: [studentId], references: [id])
  tutor           User          @relation("SessionTutor", fields: [tutorId], references: [id])
  startTime       DateTime      @db.Timestamptz(3)
  durationMinutes Int
  status          SessionStatus @default(CONFIRMED)
  notes           String        @default("")
  // Pending alt-time proposal. Which side proposed it is encoded by `status`:
  // *_BY_STUDENT means the student's proposal is awaiting the tutor's response,
  // and vice versa. A counter-proposal overwrites this and flips the status —
  // no history of earlier proposals is kept.
  proposedAltTime DateTime?     @db.Timestamptz(3)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tutorId, startTime])
  @@index([studentId, startTime])
}

model Quiz {
  id            String       @id @default(uuid()) @db.Uuid
  lessonId      String?      @db.Uuid
  lesson        Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  title         String
  // Ties a quiz to the CSV/XLSX upload that (re-)created its questions —
  // re-uploading a corrected sheet targets the same quiz + batch id rather
  // than creating a duplicate. One upload always maps to exactly one quiz.
  importBatchId String?      @db.Uuid
  questions     Question[]
  submissions   Submission[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([lessonId])
  @@index([importBatchId])
}

model Question {
  id            String       @id @default(uuid()) @db.Uuid
  quizId        String       @db.Uuid
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order         Int
  type          QuestionType
  prompt        String
  points        Float        @default(1)
  explanation   String       @default("")
  options       String[]     @default([])
  // Shape depends on `type` — validated by Zod in src/lib/quiz/schema.ts
  // (mirrors the ContentBlock.data pattern from the content model).
  correctAnswer Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([quizId, order])
}

model Submission {
  id          String           @id @default(uuid()) @db.Uuid
  studentId   String           @db.Uuid
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId      String           @db.Uuid
  quiz        Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  // { questionId, response }[] — response shape depends on the question's type
  answers     Json
  autoScore   Float?
  manualScore Float?
  status      SubmissionStatus
  feedback    String           @default("")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // One live submission per student per quiz — resubmitting overwrites the
  // previous attempt rather than creating a new row.
  @@unique([studentId, quizId])
}
