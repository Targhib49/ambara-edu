# --- Supabase / Postgres ---------------------------------------------------
# Both come from Dashboard → Connect. The pooler host prefix varies by project
# (aws-0-... / aws-1-...); don't use the direct db.*.supabase.co string — it's
# IPv6-only without the IPv4 add-on.
#
# "Transaction pooler" string (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"
# "Session pooler" string (port 5432) — used by Prisma migrations + seed
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Supabase project (Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# Publishable key (sb_publishable_...) — safe for the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_PASTE_ME"
# Secret key (sb_secret_...) — server-only, used for creating student accounts + storage admin
SUPABASE_SECRET_KEY="sb_secret_PASTE_ME"

# --- Email (session scheduling notifications) -------------------------------
# From resend.com/api-keys. Without a verified sending domain, Resend's
# sandbox mode only delivers to the email on your Resend account — fine for
# testing as the tutor, but student addresses won't receive anything until
# you verify a domain.
RESEND_API_KEY="re_PASTE_ME"
RESEND_FROM_EMAIL="Tutor LMS <onboarding@resend.dev>"

# --- Seed -------------------------------------------------------------------
SEED_TUTOR_EMAIL="targhib.ibrahim49@gmail.com"
SEED_TUTOR_PASSWORD="change-me-tutor-123"
SEED_STUDENT_PASSWORD="change-me-student-123"
